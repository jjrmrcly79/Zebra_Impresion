# Copia a .env y ajusta. NUNCA commitear .env.
PORT=7777

# Nombre EXACTO de la cola CUPS (lpstat -p). Default detectado en esta Mac:
PRINTER_NAME=Zebra_Technologies_ZTC_ZC300

# Tamaño de tarjeta del PPD: CR80 | CR81 | CR82
PAGE_SIZE=CR80

# Ribbon instalado: 0YMCKO | 1YMCKOK | 2HalfYMCKO | ...
# YMCKOK = frente color + reverso negro (dos caras)
RIBBON=1YMCKOK

# Token simple que las apps (Vecinity, nexia-tienda) deben mandar en
# el header x-print-token para poder imprimir. Cambialo.
PRINT_TOKEN=nexia-local-dev

# true = no manda a la impresora, solo guarda el PDF/PNG en tmp/ (para probar sin gastar tarjetas)
DRY_RUN=false

# URL que codifica el QR del reverso por default (las apps pueden mandar otra por tarjeta).
# OJO: NEXIA-OS lista la prod como vecinovigilante.nexiasoluciones.com.mx — confirmar la final.
DEFAULT_QR_URL=https://vecinovigilante.nexiasoluciones.com.mx

# Impresión por lote desde Supabase (schema vecino). Server-side (localhost) — nunca al navegador.
SUPABASE_URL=https://supabase.nexiasoluciones.com.mx
SUPABASE_SERVICE_ROLE_KEY=
